generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model pessoas_apollo_b2b_2 {
  id                String    @id @default(uuid())

  company_name      String?
  company_domain    String?
  lead_name         String?
  job_title         String?
  seniority_level   String?
  department        String?
  email             String?
  phone             String?
  linkedin_url      String?
  relevance_score   Int?
  lead_source       String?
  is_decision_maker Boolean?
  enrichment_date   DateTime?
  status            String?
  notes             String?
  contact_id        String?
  contacted         Boolean?  @default(false)

  created_at        DateTime? @default(now())
  updated_at        DateTime? @updatedAt

  @@map("pessoas_apollo_b2b_2")
}

model empresas_enriquecidas_2 {
  id                  String   @id @default(uuid())

  company_name        String?
  website             String?
  linkedin_url        String?
  industry            String?
  num_employees       Int?
  phone               String?
  city                String?
  state               String?
  country             String?
  primary_domain      String?
  street_address      String?
  postal_code         String?

  origin              String?
  description         String?
  mockup_link         String?
  logo_url            String?
  organization_id     String?
  people_enrichement  Boolean?
  finalidade          String?

  created_at          DateTime? @default(now())
  updated_at          DateTime? @updatedAt

  @@map("empresas_enriquecidas_2")
}

model company_actions {
  id                String    @id @default(uuid())
  company_domain    String    @unique
  contacted         Boolean   @default(false)
  contacted_by      String?
  contacted_at      DateTime?
  sent_to_hubspot   Boolean   @default(false)
  sent_to_hubspot_at DateTime?
  follow_up_date    DateTime?
  follow_up_notes   String?
  hubspot_deal_id        String?
  hubspot_owner_id       String?
  vendedor_responsavel   String?
  hubspot_status         String?
  hubspot_deal_stage     String?
  hubspot_last_synced_at DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  @@map("company_actions")
}

model action_logs {
  id          String   @id @default(uuid())
  user_email  String
  action_type String
  entity_type String
  entity_id   String
  details     Json?
  created_at  DateTime @default(now())

  @@map("action_logs")
}
